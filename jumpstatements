#break statement
for i in range(1,11):
    if(i==5):
        break
    print(i)

#continue statement
for i in range(1,11):
    if(i==5):
        continue
    print(i)

#WAP to print the multiplication table of 5 with only even multiplies
num=int(input("Enter a number:"))
for i in range(1, 11):
    num=num*i
    if num%2==0:
        print(f"{num}*{i}={num}")
